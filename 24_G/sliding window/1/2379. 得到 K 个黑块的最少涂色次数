                cnt -= 1
            if i >= k - 1:
                res = min(res, cnt)
        return res




class Solution {
    public int minimumRecolors(String blocks, int k) {
        int res = Integer.MAX_VALUE;
        int cnt = 0;
        for(int i = 0; i < blocks.length(); i++) {
            char c = blocks.charAt(i);
            if (c == 'W') cnt += 1;
            if (i >= k && blocks.charAt(i-k) == 'W') cnt -= 1;
            if (i >= k - 1) res = Math.min(res, cnt);
        }
        return res;
    }
}




