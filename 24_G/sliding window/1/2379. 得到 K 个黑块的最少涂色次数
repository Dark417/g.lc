2379. 得到 K 个黑块的最少涂色次数



class Solution:
    def minimumRecolors(self, blocks: str, k: int) -> int:
        cnt = Counter(blocks[:k])
        res = cnt["W"]
        for i in range(k, len(blocks)):
            cnt[blocks[i]] += 1
            cnt[blocks[i - k]] -= 1
            res = min(res, cnt["W"])
        return res



def minimumRecolors(self, blocks: str, k: int) -> int:
        res = inf
        cnt = 0
        for i in range(len(blocks)):
            c = blocks[i]
            if c == "W":
                cnt += 1
