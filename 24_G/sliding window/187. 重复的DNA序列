187. 重复的DNA序列

def findRepeatedDnaSequences(self, s: str) -> List[str]:
        if len(s) < 10:
            return []

        res = set()
        ss = set()

        for i in range(len(s) - 9):
            cur = s[i:i+10]
            if cur in ss:
                res.add(cur)
                ss.remove(cur)
            else:
                ss.add(cur)

        return list(res)


