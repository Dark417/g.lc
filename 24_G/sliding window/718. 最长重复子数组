# 718. 最长重复子数组

# hash + bs
def findLength(self, A: List[int], B: List[int]) -> int:
    base, mod = 113, 10**9 + 9

    def check(length: int) -> bool:
        hashA = 0
        for i in range(length):
            hashA = (hashA * base + A[i]) % mod
        bucketA = {hashA}
        mult = pow(base, length - 1, mod)
        for i in range(length, len(A)):
            hashA = ((hashA - A[i - length] * mult) * base + A[i]) % mod
            bucketA.add(hashA)
        
        hashB = 0
        for i in range(length):
            hashB = (hashB * base + B[i]) % mod
        if hashB in bucketA:
            return True
        for i in range(length, len(B)):
            hashB = ((hashB - B[i - length] * mult) * base + B[i]) % mod
            if hashB in bucketA:
                return True

        return False

    left, right = 0, min(len(A), len(B))
    ans = 0
    while left <= right:
        mid = (left + right) // 2
        if check(mid):
            ans = mid
            left = mid + 1
        else:
            right = mid - 1
    return ans






# dp

def findLength(self, nums1: List[int], nums2: List[int]) -> int:
    n, m = len(nums1), len(nums2)
    dp = [[0] * (m + 1) for _ in range(n + 1)]
    ans = 0

    for i in range(1, n + 1):
        for j in range(1, m + 1):
            dp[i][j] = dp[i - 1][j - 1] + 1 if nums1[i-1] == nums2[j-1] else 0
            ans = max(ans, dp[i][j])
    return ans


