424. 替换后的最长重复字符


def characterReplacement(self, s: str, k: int) -> int:
    cnt = {}
    n = len(s)
    mxn = l = 0

    for i in range(n):
        cnt[s[i]] = cnt.get(s[i], 0) + 1
        mxn = max(mxn, cnt[s[i]])
        if i - l + 1 > mxn + k:
            cnt[s[l]] -= 1
            l += 1

    return n - l


        
def characterReplacement(self, s: str, k: int) -> int:
    num = [0] * 26
    n = len(s)
    maxn = left = right = 0

    while right < n:
        num[ord(s[right]) - ord("A")] += 1
        maxn = max(maxn, num[ord(s[right]) - ord("A")])
        if right - left + 1 - maxn > k:
            num[ord(s[left]) - ord("A")] -= 1
            left += 1
        right += 1
    
    return right - left





public int characterReplacement(String s, int k) {
    int[] num = new int[26];
    int n = s.length();
    int maxn = 0;
    int left = 0, right = 0;
    while (right < n) {
        num[s.charAt(right) - 'A']++;
        maxn = Math.max(maxn, num[s.charAt(right) - 'A']);
        if (right - left + 1 - maxn > k) {
            num[s.charAt(left) - 'A']--;
            left++;
        }
        right++;
    }
    return right - left;
}












