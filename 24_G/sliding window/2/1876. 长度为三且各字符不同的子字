1876. 长度为三且各字符不同的子字符串



def countGoodSubstrings(self, s: str) -> int:
    if len(s) < 3:
        return 0
    res = 0
    for i in range(len(s)-2):
        curs = s[i: i+3]
        if len(set(curs)) == 3:
            res += 1
    return res


        

def countGoodSubstrings(self, s: str) -> int:
    if len(s) < 3:
        return 0
    res = 0
    for i in range(len(s)-2):
        if s[i] != s[i+1] and s[i] != s[i+2] and s[i+1] != s[i+2]:
            res += 1
    return res