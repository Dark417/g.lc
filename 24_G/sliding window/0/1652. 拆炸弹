1652. 拆炸弹

class Solution:
    def decrypt(self, code: List[int], k: int) -> List[int]:
        if k == 0:
            return [0] * len(code)
        res = []
        n = len(code)
        code += code
        if k > 0:
            l, r = 1, k
        else:
            l, r = n + k, n - 1
        w = sum(code[l:r+1])
        for i in range(n):
            res.append(w)
            w -= code[l]
            w += code[r + 1]
            l, r = l + 1, r + 1
        return res



class Solution:
    def decrypt(self, code: List[int], k: int) -> List[int]:
        return list(map(lambda i:0 if not k else sum((3*code)[len(code)+i+k//abs(k):len(code)+i+k//abs(k)+k:k//abs(k)]),range(len(code))))





def decrypt(self, code: List[int], k: int) -> List[int]:
    n = len(code)
    ans = [0] * n
    r = k + 1 if k > 0 else n
    k = abs(k)
    s = sum(code[r - k: r])  # ans[0]
    for i in range(n):
        ans[i] = s
        s += code[r % n] - code[(r - k) % n]
        r += 1
    return ans




class Solution:
    def decrypt(self, code: List[int], k: int) -> List[int]:
        n = len(code)
        ans = [0] * n
        if k == 0:
            return ans
        sum = [0] * (2 * n + 10)
        for i in range(1, 2 * n + 1):
            sum[i] = sum[i - 1] + code[(i - 1) % n]
        for i in range(1, n + 1):
            ans[i - 1] = sum[i + n - 1] - sum[i + n + k - 1] if k < 0 else sum[i + k] - sum[i]
        return ans





