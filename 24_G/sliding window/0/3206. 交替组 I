def numberOfAlternatingGroups(self, colors: List[int]) -> int:
    n = len(colors)
    cnt = 0
    for i in range(n):
        if colors[i] != colors[i-1] and colors[i] != colors[(i+1)%n]:
            cnt += 1
    return cnt


        
def numberOfAlternatingGroups(self, colors: List[int], k: int) -> int:
    n = len(colors)
    ans = cnt = 0
    for i in range(n * 2):
        if i > 0 and colors[i % n] == colors[(i - 1) % n]:
            cnt = 0
        cnt += 1
        if i >= n and cnt >= k:
            ans += 1
    return ans
















