def longestNiceSubstring(self, s: str) -> str:
    n = len(s)
    maxPos, maxLen = 0, 0
    for i in range(n):
        lower, upper = 0, 0
        for j in range(i, n):
            if s[j].islower():
                lower = lower | (1 << (ord(s[j]) - ord('a')))  # Replacing lower |=
            else:
                upper = upper | (1 << (ord(s[j]) - ord('A')))  # Replacing upper |=
            if lower == upper and j - i + 1 > maxLen:
                maxPos = i
                maxLen = j - i + 1
    return s[maxPos: maxPos + maxLen]



