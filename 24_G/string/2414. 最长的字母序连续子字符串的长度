2414. 最长的字母序连续子字符串的长度


class Solution:
    def longestContinuousSubstring(self, s: str) -> int:
        cnt = 1
        res = 1
        for i in range(1, len(s)):
            if ord(s[i]) - ord(s[i-1]) == 1:
                cnt += 1
            else:
                cnt = 1
            res = max(cnt, res)
        return res



