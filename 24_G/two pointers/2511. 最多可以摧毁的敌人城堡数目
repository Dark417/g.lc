2511. 最多可以摧毁的敌人城堡数目


class Solution:
    def captureForts(self, forts: List[int]) -> int:
        res = 0
        pre = -1
        for i in range(len(forts)):
            cur = forts[i]
            if cur == 1 or cur == -1:
                if pre >= 0 and cur != forts[pre]:
                    res = max(res, i - pre - 1)
                pre = i
        return res


class Solution:
    def captureForts(self, forts: List[int]) -> int:
        last = None
        cnt = res = 0
        for fort in forts:
            if fort == 0:
                cnt += 1
                continue
            elif last is None:
                last = fort
            elif fort != last:
                res = max(res, cnt)
                last = -last
            cnt = 0
        return res





        